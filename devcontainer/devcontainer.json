{
  "name": "JavaScript Student Workspace",
  "image": "mcr.microsoft.com/devcontainers/javascript-node:20",
  "customizations": {
    "vscode": {
      "settings": {
        "editor.tabSize": 4,
        "editor.wordWrap": "on",
        "files.autoSave": "onWindowChange"
      },
      "extensions": [
        "dbaeumer.vscode-eslint",
        "ms-vsliveshare.vsliveshare",
        "formulahendry.code-runner"
      ]
    }
  }
}
